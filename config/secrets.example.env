# ──────────────────────────────────────────────────────────────
#  secrets.example.env — PUBLIC TEMPLATE (no real keys here)
#
#  Copy to config/secrets.env (gitignored) and fill in your own values.
#
#      cp config/secrets.example.env config/secrets.env
#
#  NEVER put real keys in this example file. NEVER commit secrets.env.
#  Use exchange API keys with TRADE permission only — NEVER withdrawal.
# ──────────────────────────────────────────────────────────────

# Exchange (only needed to PLACE trades; public market data needs no key)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# On-chain data providers (free tiers)
ETHERSCAN_API_KEY=
# DEFILLAMA needs no key

# Sentiment sources
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crypto-signal-bot/0.1 by <your_reddit_username>
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram notifications (DM yourself signals/summaries)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
