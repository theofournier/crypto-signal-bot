# Keep the image small and — most importantly — keep the private edge OUT.
# Image layers are inspectable; anything COPYed in is effectively published.

# ── Secrets & tuned config (provided at RUNTIME, never baked in) ──
config/config.yaml
config/secrets.env
secrets.env
*.env
!*.example.env

# ── Private data: the journal, models, reports, raw dumps ──
storage.db
*.db
*.sqlite
*.sqlite3
data/raw/
models/
postmortem_reports/
logs/
*.log
*.csv

# ── Python caches & local virtualenv ──
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── VCS / CI / editor / OS cruft ──
.git/
.gitignore
.github/
.vscode/
.idea/
.DS_Store

# ── Docs not needed at runtime ──
*.md
LICENSE
